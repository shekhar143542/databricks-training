-- Query 9
SELECT text_value,
CASE
    WHEN text_value REGEXP '^[A-Za-z0-9._-]+@[A-Za-z0-9]+\\.[A-Za-z]{2,3}$'
    THEN 'Correct Email'
    ELSE 'Wrong Email'
END AS email_check
FROM regex_data;

Output:
| text_value        | email_check  |
| ----------------- | ------------ |
| 123ABc            | Wrong Email  |
| abc123            | Wrong Email  |
| 123abc567         | Wrong Email  |
| abcdefghi123      | Wrong Email  |
| swaroop@gmail.com | Correct Email|
| +91-9989454737    | Wrong Email  |


-- Query 10
SELECT text_value,
CASE
    WHEN text_value REGEXP '^\\+91-[0-9]{10}$'
    THEN 'Valid Number'
    ELSE 'Invalid Number'
END AS phone_check
FROM regex_data;

Output:
| text_value        | phone_check   |
| ----------------- | ------------- |
| 123ABc            | Invalid Number|
| abc123            | Invalid Number|
| 123abc567         | Invalid Number|
| abcdefghi123      | Invalid Number|
| swaroop@gmail.com | Invalid Number|
| +91-9989454737    | Valid Number  |
