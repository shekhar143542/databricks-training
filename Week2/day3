CREATE TABLE regex_data (
    id INT,
    text_value VARCHAR(100)
);

INSERT INTO regex_data VALUES
(1, '123ABc'),
(2, 'abc123'),
(3, '123abc567'),
(4, 'abcdefghi123'),
(5, 'swaroop@gmail.com'),
(6, '+91-9989454737');


-- Query 1
SELECT text_value,
       text_value REGEXP '[0-9]' AS contains_number
FROM regex_data;

Output:
| text_value        | contains_number |
| ----------------- | --------------- |
| 123ABc            | 1               |
| abc123            | 1               |
| 123abc567         | 1               |
| abcdefghi123      | 1               |
| swaroop@gmail.com | 0               |
| +91-9989454737    | 1               |


